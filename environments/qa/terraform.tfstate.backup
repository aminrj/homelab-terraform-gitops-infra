            "metadata": [
              {
                "app_version": "1.25.1",
                "chart": "cloudnative-pg",
                "first_deployed": 1743756742,
                "last_deployed": 1743756742,
                "name": "cloudnative-pg",
                "namespace": "cnpg-qa",
                "notes": "CloudNativePG Grafana Dashboard installed successfully.\nDEPRECATION NOTICE: The grafanaDashboard.sidecarLabel is deprecated and will be removed in a future release. Use the grafanaDashboard.labels instead.\n\n\nCloudNativePG operator should be installed in namespace \"cnpg-qa\".\nYou can now create a PostgreSQL cluster with 3 nodes as follows:\n\ncat \u003c\u003cEOF | kubectl apply -f -\n# Example of PostgreSQL cluster\napiVersion: postgresql.cnpg.io/v1\nkind: Cluster\nmetadata:\n  name: cluster-example\n  \nspec:\n  instances: 3\n  storage:\n    size: 1Gi\nEOF\n\nkubectl get -A cluster\n\n",
                "revision": 1,
                "values": "{\"crds\":{\"create\":true},\"monitoring\":{\"grafanaDashboard\":{\"create\":true,\"labels\":{\"grafana_dashboard\":\"1\"}},\"podMonitorEnabled\":true,\"prometheusRuleEnabled\":true},\"pgAdmin\":{\"enabled\":true,\"env\":{\"email\":\"admin@example.com\",\"password\":\"supersecret\"},\"image\":{\"repository\":\"dpage/pgadmin4\",\"tag\":\"8.2\"},\"ingress\":{\"enabled\":false},\"persistentVolume\":{\"enabled\":false},\"service\":{\"type\":\"ClusterIP\"}},\"storage\":{\"storageClass\":\"cnpg-longhorn\"}}",
                "version": "0.23.2"
              }
            ],
            "name": "cloudnative-pg",
            "namespace": "cnpg-qa",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://cloudnative-pg.github.io/charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "crds:\n  create: true\nstorage:\n  storageClass: \"cnpg-longhorn\"\n\npgAdmin:\n  enabled: true\n  image:\n    repository: dpage/pgadmin4\n    tag: \"8.2\"\n  service:\n    type: ClusterIP  # or LoadBalancer if you want it accessible externally\n  ingress:\n    enabled: false   # or true if you plan to expose it via ingress-nginx\n  env:\n    email: \"admin@example.com\"\n    password: \"supersecret\"\n  persistentVolume:\n    enabled: false   # you can set true and configure pvc if you want persistence\n\nmonitoring:\n  podMonitorEnabled: true\n  prometheusRuleEnabled: true\n  grafanaDashboard:\n    create: true\n    labels:\n      grafana_dashboard: \"1\"\n"
            ],
            "verify": false,
            "version": "0.23.2",
